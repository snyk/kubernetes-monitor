# Snyk (https://snyk.io) policy file, patches or ignores known vulnerabilities.
#
# Path wildcard ('*'):
# - SNYK-RHEL9-* and other OS findings: SCA policy paths are not expressed per-RPM in .snyk;
#   '*' applies the ignore to the scanned UBI image as a whole. Prefer fixing via dnf upgrade
#   and shrinking the image; re-verify on expiry.
# - SNYK-GOLANG-* from container scans: module paths on compiled binaries are not stable to
#   express as filesystem paths here; '*' is the supported scope.
# - Expiry: critical grpc-in-skopeo (SNYK-GOLANG-GOOGLEGOLANGORGGRPC-15691172) max 14 days;
#   all other ignores max 30 days — renew or remove on expiry.
# - Prefer removing ignores when lockfile/package versions are already patched (see git history
#   for npm cleanups) rather than widening policy.

version: v1.25.1
ignore:
  SNYK-GOLANG-GITHUBCOMCONTAINERSSTORAGE-8230413:
    - '*':
        reason: >-
          Container scan: github.com/containers/storage is pulled in via distro skopeo stack
          (not a Node devDependency). No fixed UBI/Alpine skopeo/containers-common rebuild
          available at policy update; re-check on image refresh.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-GOLANG-GOOGLEGOLANGORGGRPC-15691172:
    - '*':
        reason: >-
          Container scan: distro skopeo 1.20.0 (Alpine 3.23 / UBI 9.7) embeds
          google.golang.org/grpc v1.72.2 (verified: go version -m on Alpine /usr/bin/skopeo).
          Fix requires grpc >= 1.79.3; no patched skopeo package yet. Not network-exposed as a
          gRPC server in this image. Re-check when skopeo RPM/apk updates.
        expires: 2026-04-07T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-GNUPG2-15127565:
    - '*':
        reason: No fix in UBI 9 repositories yet; tracked via Red Hat errata. Re-verify after dnf upgrade in build.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-GNUPG2-15127613:
    - '*':
        reason: No fix in UBI 9 repositories yet; tracked via Red Hat errata. Re-verify after dnf upgrade in build.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-LIBARCHIVE-15601053:
    - '*':
        reason: No fix supported by Red Hat yet for UBI 9 libarchive; re-verify after base image bump.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-LIBXML2-13863026:
    - '*':
        reason: No upstream fix available in UBI 9 channels at last check; re-verify on quarterly image refresh.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-PYTHON3PIPWHEEL-14916305:
    - '*':
        reason: >-
          Red Hat assessed CVE-2024-47081 as not relevant for RHEL 9 / this distribution.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-TAR-15041307:
    - '*':
        reason: No fix in UBI 9 repositories yet for tar; re-verify after dnf upgrade.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-TAR-15041355:
    - '*':
        reason: No fix in UBI 9 repositories yet for tar; re-verify after dnf upgrade.
        expires: 2026-04-23T00:00:00.000Z
        created: 2026-03-24T00:00:00.000Z
  SNYK-RHEL9-TAR-15145598:
    - '*':
        reason: No fix in UBI 9 repositories yet for tar; re-verify after dnf upgrade.
        expires: 2026-04-23T00:00:00.000Z
